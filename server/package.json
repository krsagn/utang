{
  "name": "utang",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "nodemon --exec tsx -r dotenv/config src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx -r dotenv/config scripts/reset-db.ts",
    "db:seed": "tsx -r dotenv/config scripts/seed-db.ts",
    "db:fresh": "npm run db:reset && npm run db:seed",
    "test:coverage": "vitest run --coverage",
    "worker": "tsx -r dotenv/config src/workers/emailWorker.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@lucia-auth/adapter-drizzle": "^1.1.0",
