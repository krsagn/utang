    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
